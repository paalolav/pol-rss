{
  "name": "pol-rss-gallery",
  "version": "1.3.0",
  "private": true,
  "engines": {
    "node": ">=22.14.0 < 23.0.0"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "gulp bundle",
    "clean": "gulp clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "test:spfx": "gulp test",
    "test:security": "jest --testPathPattern=\"(contentSanitizer|urlValidator|cspCompliance|propertyValidators)\"",
    "test:e2e": "npx playwright test",
    "test:e2e:local": "npx playwright test --project=local-workbench",
    "test:e2e:spo": "npx playwright test --project=sharepoint-chromium",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report playwright-report",
    "lint": "eslint ./src --ext .ts,.tsx",
    "serve": "gulp serve",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:prod": "npm audit --omit=dev",
    "security:check": "npm audit && npm outdated"
  },
  "dependencies": {
    "@fluentui/react": "^8.106.4",
    "@microsoft/sp-adaptive-card-extension-base": "1.21.1",
    "@microsoft/sp-component-base": "1.21.1",
    "@microsoft/sp-core-library": "1.21.1",
    "@microsoft/sp-lodash-subset": "1.21.1",
    "@microsoft/sp-office-ui-fabric-core": "1.21.1",
    "@microsoft/sp-property-pane": "1.21.1",
    "@microsoft/sp-webpart-base": "1.21.1",
    "dompurify": "^3.3.0",
    "html-react-parser": "^5.2.3",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "swiper": "^11.2.6",
    "tslib": "2.3.1"
  },
  "devDependencies": {
    "@microsoft/eslint-config-spfx": "1.21.1",
    "@microsoft/eslint-plugin-spfx": "1.21.1",
    "@microsoft/rush-stack-compiler-5.3": "0.1.0",
    "@microsoft/sp-build-web": "1.21.1",
    "@microsoft/sp-module-interfaces": "1.21.1",
    "@playwright/test": "^1.57.0",
    "@rushstack/eslint-config": "4.0.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^12.1.5",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.12",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@types/webpack-env": "~1.15.2",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "ajv": "^6.12.5",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.3.0",
    "fake-indexeddb": "^6.2.5",
    "gulp": "4.0.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "ts-jest": "^29.1.2",
    "typescript": "4.9",
    "worker-loader": "^3.0.8"
  }
}
